from "../sig-pop/zok_src/zok_utils/unsafe_witness/big_nat/mod_arithmetic" import BigNat, modulo_reduce, integer_to_bignat, multiply, UncheckedBigNat, check_bignat_w_bitlen

// Provided by the server based the on p and q it generated during KeyGen
const integer N = 

def main(UncheckedBigNat<17> M, UncheckedBigNat<17> R) -> BigNat<17>:
    BigNat<17> checked_M = check_bignat_w_bitlen::<17, 8>(M, 124, 2048)
    BigNat<17> checked_R = check_bignat_w_bitlen::<17, 8>(R, 124, 2048)
    BigNat<34> prod = multiply::<17, 17, 34>(checked_M,checked_R)
    BigNat<17> checked_O = integer_to_bignat::<17, 124>(N)
    BigNat<17> out = modulo_reduce::<34, 17, 8>(prod, checked_O)
    return out